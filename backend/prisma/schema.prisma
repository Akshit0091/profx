generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  phone        String?
  isAdmin      Boolean       @default(false)
  isActive     Boolean       @default(false)
  createdAt    DateTime      @default(now())

  // Which marketplaces this user has access to.
  // Values: "flipkart", "meesho", "amazon". Existing users backfill to ["flipkart"].
  plans        String[]      @default([])

  // Amazon seller type: "easyship", "selfship", or "both". Null = not set yet.
  amazonSellerType String?

  subscription Subscription?
  skus         SKU[]
  orders       Order[]
  settlementEntries SettlementEntry[]
  uploadLogs   UploadLog[]
  shippingRates ShippingRate[]
}

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  razorpaySubscriptionId String?
  razorpayCustomerId     String?
  razorpayPaymentId      String?

  plan                   String   @default("starter")
  amount                 Int      @default(59900)
  status                 String   @default("pending") // pending | active | expired | cancelled

  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SKU {
  id            String   @id @default(cuid())
  skuId         String
  purchasePrice Float
  weight        Int?          // Weight in grams. Needed for Self Ship Amazon shipping cost calculation.

  // Which marketplace this SKU price belongs to. Same physical product may be
  // listed at different prices per platform, so price is scoped per platform.
  platform      String   @default("flipkart")

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([skuId, userId, platform])
  @@index([userId, platform])
}

model Order {
  id             String    @id @default(cuid())
  orderItemId    String
  orderId        String?
  skuId          String?

  // Which marketplace this order is from. Default flipkart for existing data.
  platform       String    @default("flipkart")

  dispatchDate   DateTime?
  bankSettlement Float?
  paymentDate    DateTime?

  purchasePrice  Float?
  profit         Float?

  hasPickup      Boolean   @default(false)
  hasSettlement  Boolean   @default(false)
  isMatched      Boolean   @default(false)

  trackingId     String?

  isReturned     Boolean   @default(false)
  returnDate     DateTime?

  // Distinguishes return sub-types. For Flipkart: null or "returned".
  // For Meesho: "rto" (never delivered, settlement 0) vs "return" (came back, reverse fee).
  returnType            String?

  // Amazon fulfillment: "merchant" (Self Ship) or "amazon" (Easy Ship/FBA). Null for Flipkart/Meesho.
  fulfillmentType       String?
  // Shipping cost for Self Ship orders (calculated from SKU weight + seller's rate card).
  shippingCost          Float?

  returnIncoming        Boolean   @default(false)
  returnRequestedDate   DateTime?
  returnReason          String?
  returnSubReason       String?
  returnStatus          String?

  isStarred             Boolean   @default(false)
  starredAt             DateTime?

  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([orderItemId, userId, platform])
  @@index([userId, platform])
  @@index([trackingId])
  @@index([skuId])
}

// One row per Flipkart settlement line item.
// Multiple entries for the same orderItemId accumulate — the Order's
// bankSettlement is always the SUM of its entries.
//
// fileHash = SHA-256 of the uploaded file's bytes.  When the same file is
// re-uploaded, all of that fileHash's entries are deleted and re-inserted,
// so re-uploads are idempotent.  Different files contribute their own entries
// independently, and the sum naturally reflects all of them.
model SettlementEntry {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform       String    @default("flipkart")

  orderItemId    String
  orderId        String?
  paymentDate    DateTime?
  bankSettlement Float

  fileHash       String
  fileName       String?
  rowIndex       Int       // position within the file, for re-upload stability

  createdAt      DateTime  @default(now())

  @@index([userId, platform, orderItemId])
  @@index([userId, fileHash])
}

model UploadLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  type        String
  fileName    String?
  fileHash    String?
  rowCount    Int      @default(0)
  inserted    Int      @default(0)
  updated     Int      @default(0)
  affectedIds String[] @default([])
  createdAt   DateTime @default(now())

  @@index([userId, platform])
  @@index([userId, fileHash])
}

model ShippingRate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  minWeight Int      // grams
  maxWeight Int      // grams
  cost      Float    // ₹ per shipment
  createdAt DateTime @default(now())

  @@index([userId])
}
